{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "datafactory-demo-dev"
		},
		"cicd_kv_link_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://cicd-demo-kv.vault.azure.net/"
		},
		"demodatahk_link_properties_typeProperties_connectionString_secretName": {
			"type": "string",
			"defaultValue": "demodatahk-key"
		},
		"new_receipt_trigger_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/1879aa43-d608-46e4-a785-0d32acda95a4/resourceGroups/form-recognizer-rg/providers/Microsoft.Storage/storageAccounts/demodatahk"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "datafactory-demo-dev_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2018-02-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"cicd_kv_link_properties_typeProperties_baseUrl": {
						"value": "[parameters('cicd_kv_link_properties_typeProperties_baseUrl')]"
					},
					"demodatahk_link_properties_typeProperties_connectionString_secretName": {
						"value": "[parameters('demodatahk_link_properties_typeProperties_connectionString_secretName')]"
					},
					"new_receipt_trigger_properties_typeProperties_scope": {
						"value": "[parameters('new_receipt_trigger_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}